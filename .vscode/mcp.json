{
  "servers": {
    "football-odds-api": {
      "type": "http",
      "url": "https://api.the-odds-api.com/v4/sports/",
      "headers": {
        "Content-Type": "application/json"
      },
      "env": {
        "ODDS_API_KEY": "${ODDS_API_KEY}"
      }
    },
    "stitch": {
      "type": "http",
      "url": "https://stitch.googleapis.com/mcp",
      "headers": {
        "X-Goog-Api-Key": "${GOOGLE_STITCH_API_KEY}"
      }
    }
  }
}
